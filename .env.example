# Copy this file to .env.local for local development.
# Real secrets should never be committed.
VITE_API_URL=http://localhost:8000
SUPABASE_URL=https://your-project.supabase.co/rest/v1/
SUPABASE_KEY=your-supabase-key
TEST_USER_ID=your-test-user-id
VITE_TEST_USER_ID=your-test-user-id
ALLOW_DEV_BYPASS_AUTH=true
VITE_ENABLE_DEV_BYPASS=true
